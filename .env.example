# Supabase Configuration
# Get these from your Supabase project settings

# Your Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Anon Key (use this for client-side operations)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (optional, for server-side operations with elevated privileges)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Notes:
# - Replace the URLs and keys with YOUR actual credentials
# - SUPABASE_ANON_KEY is for public operations
# - SUPABASE_KEY is for admin operations (keep it private!)
# - This file is in .gitignore and will NOT be committed
