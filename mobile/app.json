{
  "expo": {
    "name": "KrishiMitra",
    "slug": "krishimitra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "krishimitra",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "KrishiMitra needs microphone access for voice queries in Kannada",
        "NSCameraUsageDescription": "KrishiMitra needs camera access for crop disease diagnosis",
        "NSPhotoLibraryUsageDescription": "KrishiMitra needs photo library access for crop images"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2E7D32"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ],
      "package": "com.nivettisystems.krishimitra"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "KrishiMitra needs microphone for voice queries"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "KrishiMitra needs camera for crop diagnosis",
          "photosPermission": "KrishiMitra needs gallery for crop images"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
